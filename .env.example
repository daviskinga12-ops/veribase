# Veribase Environment Variables
# Copy this file to .env.local for local development
# Add these in your Vercel dashboard under Settings > Environment Variables

# ─── Vercel KV (for waitlist storage) ────────────────────────────────────────
# Create a KV store at: https://vercel.com/dashboard → Storage → Create KV
VERIBASE_KV_REST_API_URL=your_kv_rest_url_here
VERIBASE_KV_REST_API_TOKEN=your_kv_rest_token_here

# ─── Admin Access ─────────────────────────────────────────────────────────────
# Password to access /api/admin?password=YOUR_PASSWORD
# Choose something strong
ADMIN_PASSWORD=choose_a_strong_password_here

# ─── Optional: Email notifications ───────────────────────────────────────────
# If you want an email every time someone joins the waitlist
# Sign up free at https://resend.com
RESEND_API_KEY=your_resend_api_key_here
NOTIFY_EMAIL=hello@veribase.co
